{
  "name": "@attested-intelligence/aga-mcp-server",
  "version": "2.1.0",
  "description": "MCP server and governance proxy implementing the Attested Governance Artifact (AGA) protocol - cryptographic compliance enforcement for autonomous AI systems. 20 tools, 3 resources, 3 prompts, governance proxy.",
  "author": "Attested Intelligence Holdings LLC",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "aga-mcp-server": "dist/index.js",
    "aga-proxy": "dist/proxy/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:crypto": "vitest run tests/crypto/",
    "test:core": "vitest run tests/core/",
    "test:tools": "vitest run tests/tools/",
    "test:integration": "vitest run tests/integration/",
    "test:proxy": "vitest run tests/proxy/",
    "proxy": "tsx src/proxy/index.ts",
    "proxy:start": "tsx src/proxy/index.ts start",
    "demo": "tsx scripts/demo.ts",
    "benchmark": "tsx scripts/benchmark.ts",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.7.0",
    "commander": "^14.0.3",
    "uuid": "^11.1.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.7.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "attestation",
    "governance",
    "ai-governance",
    "ai-safety",
    "runtime-integrity",
    "continuity-chain",
    "zero-trust",
    "nist",
    "nccoe",
    "spiffe",
    "ed25519",
    "evidence-bundle",
    "policy-enforcement"
  ]
}
